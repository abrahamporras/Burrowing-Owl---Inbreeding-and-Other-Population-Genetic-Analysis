### CURATE TIME DATA

#extract date metadata
awk -F',' 'NR>1 {
  print $1, $7
}' CA_AZ_Vegas.samples.cov.master.csv > id_date_raw.txt

#convert to the binary old and new categories (as suggested by Christen, 2019 is the cutoff)
awk '{
  split($2, d, "/")
  year=d[1]

  if (year <= 2019) group="OLD"
  else group="NEW"

  print $1, year, group
}' id_date_raw.txt > id_time.txt

### JOIN FROH RESULTS WITH TIME DATA
sort froh.txt > froh.sorted.txt
sort id_time.txt > id_time.sorted.txt

join froh.sorted.txt id_time.sorted.txt > froh_time.txt

### SUMMARIZE OLD AND NEW FROH DATA
awk '{
  g=$4
  v=$2
  sum[g]+=v
  sumsq[g]+=v*v
  n[g]++
}
END {
  for (g in sum) {
    mean=sum[g]/n[g]
    var=(sumsq[g]/n[g])-(mean*mean)
    sd=sqrt(var)
    print g, n[g], mean, sd
  }
}' froh_time.txt > froh_time_summary.txt

