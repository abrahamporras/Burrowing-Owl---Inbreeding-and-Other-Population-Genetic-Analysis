#add master file so we can add dates to IDs
scp C:/Users/Owner/Downloads/SP26/BARR/BUOW/CA_AZ_Vegas.samples.cov.master.csv porr1330@khaleen.csumb.edu:/home/porr1330/bcftools_work

cd bcftools_work
conda activate genome-tools

# ------------------------------------------
# STEP 1 — confirm normalized FROH exists
# froh.txt should contain:
# sampleID   decimal_value
# ------------------------------------------
head froh.txt

# ------------------------------------------
# STEP 2 — extract VCF IDs (ground truth)
# ------------------------------------------
bcftools query -l autosomes.af.vcf.gz | sort > vcf_ids.txt

# ------------------------------------------
# STEP 3 — build metadata:
# sampleID location OLD/NEW
# columns:
# $1 = BGP_ID
# $7 = CollectionDate
# $11 = Location
# ------------------------------------------
awk -F',' 'NR>1{
    gsub(/\r/,"",$0)

    id=$1
    date=$7
    loc=$11

    split(date,t," ")
    split(t[1],d,"/")
    year=d[1]

    if(year <= 2019) grp="OLD"
    else grp="NEW"

    print id, loc, grp
}' CA_AZ_Vegas.samples.cov.master.csv | sort > metadata_raw.txt

# ------------------------------------------
# STEP 4 — keep only IDs present in VCF
# ------------------------------------------
awk 'NR==FNR{a[$1];next} $1 in a' vcf_ids.txt metadata_raw.txt \
> metadata_clean.txt

# ------------------------------------------
# STEP 5 — sort files for join
# ------------------------------------------
sort froh.txt > froh.sorted.txt
sort metadata_clean.txt > metadata.sorted.txt

# ------------------------------------------
# STEP 6 — join:
# sampleID FROH Location OLD/NEW
# ------------------------------------------
join -1 1 -2 1 froh.sorted.txt metadata.sorted.txt > froh_loc_time.txt

# ------------------------------------------
# STEP 7 — QC counts
# ------------------------------------------
echo "FROH rows:" $(wc -l < froh.sorted.txt)
echo "Metadata rows:" $(wc -l < metadata.sorted.txt)
echo "Joined rows:" $(wc -l < froh_loc_time.txt)

# ------------------------------------------
# STEP 8 — summarize by Location + TimeGroup
# output:
# Location Group N Mean SD
# ------------------------------------------
awk '{
    loc=$3
    grp=$4
    val=$2

    key=loc FS grp

    sum[key]+=val
    sumsq[key]+=val*val
    n[key]++
}
END{
    for(k in sum){
        mean=sum[k]/n[k]
        var=(sumsq[k]/n[k])-(mean*mean)
        if(var < 0) var=0
        sd=sqrt(var)

        split(k,a,FS)

        print a[1], a[2], n[k], mean, sd
    }
}' froh_loc_time.txt | sort > froh_location_oldnew_summary.txt

# ------------------------------------------
# STEP 9 — inspect results
# ------------------------------------------
cat froh_location_oldnew_summary.txt

