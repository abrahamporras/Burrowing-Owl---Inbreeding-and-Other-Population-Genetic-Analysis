###MAKING SUBSET ID VCF

#assign vcf
VCF="/home/barr7596/BUOW/BUOW.all.rm_rel1.2mind.biallelic.SNP.maf05.8miss.vcf.gz"

#extracting IDs in VCFs
bcftools query -l $VCF > vcf_samples.txt

#extarct metadata id
cut -d',' -f1 buow_withpop.csv | tail -n +2 > metadata_ids.txt

#combine metadata and vcf ids
grep -Ff metadata_ids.txt vcf_samples.txt > sample_ids.txt

#check
wc -l sample_ids.txt
#'172'

#create subset vcf
bcftools view -S sample_ids.txt -Oz -o subset.vcf.gz $VCF

#index subset vcf
bcftools index subset.vcf.gz

#compute missingness
bcftools query -f '[%SAMPLE\t%GT\n]' subset.vcf.gz | \
awk '{
  total[$1]++;
  if ($2=="./.") miss[$1]++;
}
END {
  for (s in total) {
    m = (miss[s] ? miss[s] : 0) / total[s];
    print s, m
  }
}' > sample_missingness.txt



#filter out samples with high missingness (10%)
awk '$2 <= 0.1 {print $1}' sample_missingness.txt > keep_samples.txt
wc -l keep_samples.txt

#subset again to remove high missingness samples
bcftools view -S keep_samples.txt \
  -Oz -o clean.vcf.gz subset.vcf.gz

bcftools index clean.vcf.gz

###ID Z chromosome

#convert to bed for PLINK
plink --vcf clean.vcf.gz --make-bed --out tmp

#loop
for chr in $(cut -f2 snp_counts.txt); do
  plink --bfile tmp --chr $chr --het --out het_$chr
done

#Z will be a large contig, and with heterozygosity near 0 in subset. Save this
echo "NC_1340XX.X" > sex_chr.txt

###REMOVE Z CHROMOSOME
bcftools view -T ^sex_chr.txt clean.vcf.gz -Oz -o autosomes.vcf.gz

bcftools index autosomes.vcf.gz

###add allele frequency tag
bcftools +fill-tags autosomes.vcf.gz -Oz -o autosomes.af.vcf.gz -- -t AF

bcftools index autosomes.af.vcf.gz

###RUN ROH
bcftools roh -G --AF-tag AF --rec-rate 1e-8 autosomes.af.vcf.gz > roh.txt

###ROH Per Individual
awk '$1=="RG"{sum[$2]+=$6} END{for (i in sum) print i, sum[i]}' roh.txt > roh_total_bp.txt

###COMPUTE FROH
#Determine genome length
bcftools index -n autosomes.vcf.gz

#DEFINE GENOME LENGTH
GENOME_BP=

#run and extract froh
awk -v G=$GENOME_BP '{print $1, $2/G}' roh_total_bp.txt > froh.txt

###extract IDs and populations again
cut -d',' -f1,2 buow_withpop.csv | tail -n +2 | sed 's/,/ /g' > id_pop.txt

###merge the the froh extimates with population tied to ID
join <(sort froh.txt) <(sort id_pop.txt) > froh_with_pop.txt

###POPULATION LEVEL SUMMARY
awk '{
  pop=$3;
  val=$2;
  sum[pop]+=val;
  sumsq[pop]+=val*val;
  count[pop]+=1
}
END {
  for (p in sum) {
    mean=sum[p]/count[p];
    var=(sumsq[p]/count[p])-(mean*mean);
    sd=sqrt(var);
    print p, count[p], mean, sd
  }
}' froh_with_pop.txt > pop_froh_summary.txt

###ADD '*' TO FLAG POPULATIONS SMALLER THAN 5
awk '{
  if ($2 < 5) {
    print $1"*", $2, $3, $4
  } else {
    print $1, $2, $3, $4
  }
}' pop_froh_summary.txt > pop_froh_final.txt

