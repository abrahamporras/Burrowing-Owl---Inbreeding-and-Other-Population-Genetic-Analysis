#!/bin/bash
set -euo pipefail

VCF="/home/barr7596/BUOW/BUOW.all.rm_rel1.2mind.biallelic.SNP.maf05.8miss.vcf.gz"

#subset
bcftools view -S keep_samples.txt -Oz -o clean.vcf.gz $VCF
bcftools index clean.vcf.gz

# PLINK
plink --vcf clean.vcf.gz --make-bed --allow-extra-chr --out tmp

#SNP counts (needed for Z removal step consistency)
bcftools query -f '%CHROM\n' clean.vcf.gz | \
sort | uniq -c | sort -nr > snp_counts.txt

#keep only chromosome contigs
awk '$2 ~ /^NC_/ {print $2}' snp_counts.txt > nc_contigs.txt

bcftools view -t $(paste -sd, nc_contigs.txt) clean.vcf.gz -Oz -o chrom_only.vcf.gz
bcftools index chrom_only.vcf.gz

#remove Z(imanually assigned input file from earlier)
Z=$(cat sex_chr.txt)

bcftools view -t "^$Z" chrom_only.vcf.gz -Oz -o autosomes.vcf.gz
bcftools index autosomes.vcf.gz

#add allele frequencies
bcftools +fill-tags autosomes.vcf.gz -Oz -o autosomes.af.vcf.gz -- -t AF
bcftools index autosomes.af.vcf.gz

#ROH calculation
bcftools roh --AF-tag AF --rec-rate 1e-8 autosomes.af.vcf.gz > roh.txt
awk '$1=="RG"{sum[$2]+=$5} END{for (i in sum) print i, sum[i]}' roh.txt > roh_total_bp.txt

#FROH calculation
GENOME_BP=1355857592
awk -v G=$GENOME_BP '{print $1, $2/G}' roh_total_bp.txt > froh.txt

#merge populations
cut -d',' -f1,2 buow_withpop.csv | tail -n +2 | sed 's/,/ /g' > id_pop.txt
sort froh.txt > froh.sorted.txt
sort id_pop.txt > id_pop.sorted.txt
join froh.sorted.txt id_pop.sorted.txt > froh_with_pop.txt

#summarize froh values
awk '{
  pop=$3;
  val=$2;
  sum[pop]+=val;
  sumsq[pop]+=val*val;
  count[pop]+=1
}
END {
  for (p in sum) {
    mean=sum[p]/count[p];
    var=(sumsq[p]/count[p])-(mean*mean);
    sd=sqrt(var);
    print p, count[p], mean, sd
  }
}' froh_with_pop.txt > pop_froh_summary.txt

awk '{
  if ($2 < 5) print $1"*", $2, $3, $4;
  else print $1, $2, $3, $4;
}' pop_froh_summary.txt > pop_froh_final.txt

