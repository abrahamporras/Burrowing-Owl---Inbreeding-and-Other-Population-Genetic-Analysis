#create PCA metadata file
 awk '{print $1, $3, $4}' ../../bcftools_work/froh_loc_time.txt > pca_meta.txt

#Generate BEAGLE file from VCF
angsd -vcf-gl ../../bcftools_work/autosomes.af.vcf.gz \
-doGlf 2 \
-doMajorMinor 1 \
-doMaf 1 \
-minMaf 0.05 \
-minMapQ 30 \
-minQ 20 \
-remove_bads 1 \
-only_proper_pairs 1 \
-SNP_pval 1e-6 \
-out buow

#output will be 'buow.beagle.gz'





#check metadata
head froh_loc_time.txt

#run pcangsd on all samples first
pcangsd -beagle autosomes.beagle.gz -o buow_all -threads 8

#split old and new
awk '$3=="OLD"{print $1}' froh_loc_time.txt > old_samples.txt
awk '$3=="NEW"{print $1}' froh_loc_time.txt > new_samples.txt

#subset beagle
python pcangsd/utils/subsetBeagle.py \
-beagle autosomes.beagle.gz \
-samples old_samples.txt \
-out old.beagle.gz

python pcangsd/utils/subsetBeagle.py \
-beagle autosomes.beagle.gz \
-samples new_samples.txt \
-out new.beagle.gz

#run separate pca
pcangsd -beagle old.beagle.gz -o old_pca -threads 8
pcangsd -beagle new.beagle.gz -o new_pca -threads 8

