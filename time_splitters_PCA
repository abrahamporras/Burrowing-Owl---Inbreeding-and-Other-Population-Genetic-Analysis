import pandas as pd
import matplotlib.pyplot as plt

# ---------------------------
# LOAD PCA OUTPUT
# ---------------------------
pca = pd.read_csv("pca.eigenvec", sep=" ", header=None)

pca = pca.iloc[:, :4]
pca.columns = ["FID", "IID", "PC1", "PC2"]

# ---------------------------
# LOAD METADATA
# ---------------------------
meta = pd.read_csv("pca_meta.txt", sep=" ", header=None)
meta.columns = ["IID", "POP", "GROUP"]

# ---------------------------
# MERGE
# ---------------------------
df = pd.merge(pca, meta, on="IID")

# ---------------------------
# COLORS (18 pops)
# ---------------------------
pops = sorted(df["POP"].unique())
colors = {pops[i]: plt.cm.tab20(i % 20) for i in range(len(pops))}

# =====================================================
# 1) OLD ONLY
# =====================================================
old = df[df["GROUP"] == "OLD"]

plt.figure()
for pop in pops:
    sub = old[old["POP"] == pop]
    plt.scatter(sub["PC1"], sub["PC2"], c=[colors[pop]], s=20)

plt.title("PCA - OLD Only")
plt.tight_layout()
plt.savefig("pca_old.png", dpi=300)
plt.close()

# =====================================================
# 2) NEW ONLY
# =====================================================
new = df[df["GROUP"] == "NEW"]

plt.figure()
for pop in pops:
    sub = new[new["POP"] == pop]
    plt.scatter(sub["PC1"], sub["PC2"], c=[colors[pop]], s=20)

plt.title("PCA - NEW Only")
plt.tight_layout()
plt.savefig("pca_new.png", dpi=300)
plt.close()

# =====================================================
# 3) COMBINED
# =====================================================
plt.figure()

for pop in pops:
    sub = df[df["POP"] == pop]

    old = sub[sub["GROUP"] == "OLD"]
    new = sub[sub["GROUP"] == "NEW"]

    plt.scatter(old["PC1"], old["PC2"],
                c=[colors[pop]],
                marker="o",
                s=20)

    plt.scatter(new["PC1"], new["PC2"],
                c=[colors[pop]],
                marker="^",
                s=20)

plt.title("PCA - OLD vs NEW")
plt.tight_layout()
plt.savefig("pca_combined.png", dpi=300)
plt.close()

print("DONE: PCA plots generated")

