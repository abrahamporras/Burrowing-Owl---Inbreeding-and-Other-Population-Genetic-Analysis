import pandas as pd
import matplotlib.pyplot as plt

# =========================
# LOAD DATA
# =========================

df = pd.read_csv("pca_merged.txt", sep=r"\s+", header=None)

# expected structure:
# 0 = ID
# 2 = PC1
# 3 = PC2
# last 2 columns = pop + group

df = df.iloc[:, [0,2,3,-2,-1]]
df.columns = ["id","PC1","PC2","pop","group"]

# =========================
# COLOR MAP (18 pops)
# =========================

pops = sorted(df["pop"].unique())
colors = {pops[i]: plt.cm.tab20(i % 20) for i in range(len(pops))}

# =========================
# FIGURE 1 — OLD
# =========================

old = df[df["group"] == "OLD"]

plt.figure(figsize=(7,6))
for pop in pops:
    sub = old[old["pop"] == pop]
    plt.scatter(sub["PC1"], sub["PC2"], color=colors[pop], s=20)

plt.title("PCA — OLD individuals")
plt.xlabel("PC1")
plt.ylabel("PC2")
plt.tight_layout()
plt.savefig("PCA_OLD.pdf")
plt.close()

# =========================
# FIGURE 2 — NEW
# =========================

new = df[df["group"] == "NEW"]

plt.figure(figsize=(7,6))
for pop in pops:
    sub = new[new["pop"] == pop]
    plt.scatter(sub["PC1"], sub["PC2"], color=colors[pop], s=20)

plt.title("PCA — NEW individuals")
plt.xlabel("PC1")
plt.ylabel("PC2")
plt.tight_layout()
plt.savefig("PCA_NEW.pdf")
plt.close()

# =========================
# FIGURE 3 — OVERLAY
# =========================

plt.figure(figsize=(8,6))

for pop in pops:
    sub = df[df["pop"] == pop]

    old = sub[sub["group"] == "OLD"]
    new = sub[sub["group"] == "NEW"]

    plt.scatter(old["PC1"], old["PC2"],
                color=colors[pop],
                marker="o",
                s=20)

    plt.scatter(new["PC1"], new["PC2"],
                color=colors[pop],
                marker="^",
                s=20)

plt.title("PCA — OLD vs NEW")
plt.xlabel("PC1")
plt.ylabel("PC2")
plt.tight_layout()
plt.savefig("PCA_OVERLAY.pdf")
plt.close()

