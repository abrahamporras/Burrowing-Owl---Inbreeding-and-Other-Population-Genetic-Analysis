import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
from matplotlib.patches import Ellipse
from matplotlib.lines import Line2D

# =========================
# LOAD DATA
# =========================

df = pd.read_csv("pca_merged.txt", sep=r"\s+", header=None)

# expected structure:
# 0 = sample ID
# 2 = PC1
# 3 = PC2
# last 2 columns = population + group

df = df.iloc[:, [0,2,3,-2,-1]]
df.columns = ["id","PC1","PC2","pop","group"]

# =========================
# COLOR MAP (18 pops)
# =========================

pops = sorted(df["pop"].unique())
colors = {pops[i]: plt.cm.tab20(i % 20) for i in range(len(pops))}

# =========================
# ELLIPSE FUNCTION
# =========================

def add_ellipse(x, y, ax, color):
    if len(x) < 3:
        return

    cov = np.cov(x, y)
    vals, vecs = np.linalg.eigh(cov)

    order = vals.argsort()[::-1]
    vals = vals[order]
    vecs = vecs[:, order]

    theta = np.degrees(np.arctan2(*vecs[:,0][::-1]))

    width, height = 2 * 2 * np.sqrt(vals)  # ~95% CI

    ell = Ellipse(
        xy=(np.mean(x), np.mean(y)),
        width=width,
        height=height,
        angle=theta,
        edgecolor=color,
        facecolor='none',
        linewidth=1.5,
        alpha=0.8
    )

    ax.add_patch(ell)

# =========================
# OVERLAY PCA PLOT
# =========================

fig, ax = plt.subplots(figsize=(9,7))

for pop in pops:
    sub = df[df["pop"] == pop]

    old = sub[sub["group"] == "OLD"]
    new = sub[sub["group"] == "NEW"]

    # OLD = circles
    ax.scatter(old["PC1"], old["PC2"],
               color=colors[pop],
               marker="o",
               s=20)

    # NEW = triangles
    ax.scatter(new["PC1"], new["PC2"],
               color=colors[pop],
               marker="^",
               s=20)

    # ellipse for whole population
    add_ellipse(sub["PC1"], sub["PC2"], ax, colors[pop])

# =========================
# LEGENDS
# =========================

# Shape legend
shape_legend = [
    Line2D([0], [0], marker='o', color='black', label='OLD', markersize=8, linestyle='None'),
    Line2D([0], [0], marker='^', color='black', label='NEW', markersize=8, linestyle='None')
]

shape_leg = ax.legend(handles=shape_legend,
                      title="Time group",
                      loc="upper right")

ax.add_artist(shape_leg)

# Population legend (colors only)
pop_legend = [
    Line2D([0], [0],
           marker='o',
           color=colors[pop],
           label=pop,
           linestyle='None',
           markersize=6)
    for pop in pops
]

ax.legend(handles=pop_legend,
          title="Population",
          bbox_to_anchor=(1.05, 1),
          loc="upper left",
          fontsize=8)

# =========================
# LABELS + SAVE
# =========================

ax.set_title("BUOW PCA — OLD vs NEW with Population Structure")
ax.set_xlabel("PC1")
ax.set_ylabel("PC2")

plt.tight_layout()
plt.savefig("PCA_OVERLAY_ELLIPSES.pdf", dpi=300)
plt.close()

