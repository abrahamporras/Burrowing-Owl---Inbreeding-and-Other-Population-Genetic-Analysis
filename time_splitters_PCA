import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.patches import Ellipse

# ----------------------------
# LOAD PCA
# ----------------------------
pca = pd.read_csv(
    "pca.eigenvec",
    sep=r"\s+",
    header=None
)

# columns: IID, IID, PC1, PC2, ...
pca = pca.iloc[:, [0, 2, 3]]
pca.columns = ["sample", "PC1", "PC2"]

# ----------------------------
# LOAD METADATA
# ----------------------------
meta = pd.read_csv(
    "pca_meta_final.txt",
    sep=r"\s+",
    header=None,
    names=["sample", "pop", "time"]
)

df = pd.merge(pca, meta, on="sample")

# ----------------------------
# POP COLORS (EDIT IF NEEDED)
# ----------------------------
pops = sorted(df["pop"].unique())
colors = plt.cm.tab20(np.linspace(0, 1, len(pops)))
color_map = dict(zip(pops, colors))

# ----------------------------
# ELLIPSE FUNCTION
# ----------------------------
def draw_ellipse(x, y, ax, color, alpha=0.2):
    if len(x) < 3:
        return

    cov = np.cov(x, y)
    vals, vecs = np.linalg.eigh(cov)

    order = vals.argsort()[::-1]
    vals = vals[order]
    vecs = vecs[:, order]

    theta = np.degrees(np.arctan2(*vecs[:, 0][::-1]))

    width, height = 2 * np.sqrt(vals)

    ell = Ellipse(
        xy=(np.mean(x), np.mean(y)),
        width=width,
        height=height,
        angle=theta,
        edgecolor=color,
        facecolor=color,
        alpha=alpha
    )
    ax.add_patch(ell)

# ----------------------------
# FIGURE 1: OLD ONLY
# ----------------------------
fig, ax = plt.subplots()

old = df[df["time"] == "OLD"]

for pop in pops:
    sub = old[old["pop"] == pop]
    ax.scatter(sub["PC1"], sub["PC2"], color=color_map[pop], label=pop, s=15)
    draw_ellipse(sub["PC1"], sub["PC2"], ax, color_map[pop])

ax.set_title("PCA - OLD only")
ax.set_xlabel("PC1")
ax.set_ylabel("PC2")
ax.legend()
plt.tight_layout()
plt.savefig("PCA_OLD.png", dpi=300)
plt.close()

# ----------------------------
# FIGURE 2: NEW ONLY
# ----------------------------
fig, ax = plt.subplots()

new = df[df["time"] == "NEW"]

for pop in pops:
    sub = new[new["pop"] == pop]
    ax.scatter(sub["PC1"], sub["PC2"], color=color_map[pop], label=pop, s=15)
    draw_ellipse(sub["PC1"], sub["PC2"], ax, color_map[pop])

ax.set_title("PCA - NEW only")
ax.set_xlabel("PC1")
ax.set_ylabel("PC2")
ax.legend()
plt.tight_layout()
plt.savefig("PCA_NEW.png", dpi=300)
plt.close()

# ----------------------------
# FIGURE 3: COMBINED
# ----------------------------
fig, ax = plt.subplots()

for pop in pops:
    sub = df[df["pop"] == pop]

    old_sub = sub[sub["time"] == "OLD"]
    new_sub = sub[sub["time"] == "NEW"]

    # OLD circles
    ax.scatter(
        old_sub["PC1"], old_sub["PC2"],
        color=color_map[pop],
        marker="o",
        s=15,
        label=f"{pop} OLD"
    )

    # NEW triangles
    ax.scatter(
        new_sub["PC1"], new_sub["PC2"],
        color=color_map[pop],
        marker="^",
        s=15,
        label=f"{pop} NEW"
    )

    # ellipses separately
    draw_ellipse(old_sub["PC1"], old_sub["PC2"], ax, color_map[pop], alpha=0.15)
    draw_ellipse(new_sub["PC1"], new_sub["PC2"], ax, color_map[pop], alpha=0.15)

ax.set_title("PCA - Combined OLD vs NEW")
ax.set_xlabel("PC1")
ax.set_ylabel("PC2")

# cleaner legend (avoid explosion)
ax.legend(bbox_to_anchor=(1.05, 1), loc="upper left", fontsize=8)

plt.tight_layout()
plt.savefig("PCA_COMBINED.png", dpi=300)
plt.close()

