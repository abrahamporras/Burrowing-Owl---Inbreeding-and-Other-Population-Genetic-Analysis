### PRELIM SETUP 

cd /home/porr1330/bcftools_work

conda activate genome-tools

# VCF path
VCF="/home/barr7596/BUOW/BUOW.all.rm_rel1.2mind.biallelic.SNP.maf05.8miss.vcf.gz"

### SAMPLE SUBSETTING

# extract VCF sample IDs
bcftools query -l $VCF > vcf_samples.txt

# extract metadata IDs
cut -d',' -f1 buow_withpop.csv | tail -n +2 > metadata_ids.txt

# intersect IDs
grep -Ff metadata_ids.txt vcf_samples.txt > sample_ids.txt

# subset VCF
bcftools view -S sample_ids.txt -Oz -o subset.vcf.gz $VCF
bcftools index subset.vcf.gz

### FILTER HIGH MISSINGNESS SAMPLES

# compute missingness per sample
bcftools query -f '[%SAMPLE\t%GT\n]' subset.vcf.gz | \
awk '{
  total[$1]++;
  if ($2=="./.") miss[$1]++;
}
END {
  for (s in total) {
    m = (miss[s] ? miss[s] : 0) / total[s];
    print s, m
  }
}' > sample_missingness.txt

# keep samples <=10% missing
awk '$2 <= 0.1 {print $1}' sample_missingness.txt > keep_samples.txt

# subset again
bcftools view -S keep_samples.txt -Oz -o clean.vcf.gz subset.vcf.gz
bcftools index clean.vcf.gz

### KEEP CHROMOSOME-LEVEL CONTIGS ONLY

# list contigs + SNP counts
bcftools query -f '%CHROM\n' clean.vcf.gz | sort | uniq -c | sort -nr > snp_counts.txt

# keep only NC (chromosome-level)
awk '$2 ~ /^NC_/ {print $2}' snp_counts.txt > nc_contigs.txt

# subset to chromosomes only
bcftools view -t $(paste -sd, nc_contigs.txt) clean.vcf.gz -Oz -o chrom_only.vcf.gz
bcftools index chrom_only.vcf.gz

### REMOVE Z CHROMOSOME (DEFINED)

# confirmed Z chromosome from mentor
echo "NC_134077.1" > sex_chr.txt

# remove Z
Z=$(cat sex_chr.txt)

bcftools view -t "^$Z" chrom_only.vcf.gz -Oz -o autosomes.vcf.gz
bcftools index autosomes.vcf.gz

# verify Z removed (should return nothing)
bcftools view -r NC_134077.1 autosomes.vcf.gz | head

