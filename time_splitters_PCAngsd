
#download pcangsd into genome-tools environment

#create PCA metadata file
awk '{print $1, $3, $4}' froh_loc_time.txt > pca_meta.txt

#Generate BEAGLE file from VCF
angsd -vcf-gl autosomes.af.vcf.gz \
-doGlf 2 \
-doMajorMinor 1 \
-doMaf 1 \
-minMaf 0.05 \
-out buow

#output will be 'buow.beagle.gz'

#run pcangsd
pcangsd.py -beagle buow.beagle.gz -o buow_all -threads 8

