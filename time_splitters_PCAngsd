
### PRELIM SETUP 
cd /home/porr1330/bcftools_work
conda activate genome-tools

#run following if no pip
conda install pip

#download pcangsd into genome-tools environment
git clone https://github.com/Rosemeis/pcangsd.git
cd pcangsd
pip install .
which pcangsd
cd ~
mkdir pcangsd_work
mv bcftools_work/pcangsd pcangsd_work/
cd pcangsd_work/pcangsd
ls

#create PCA metadata file
awk '{print $1, $3, $4}' froh_loc_time.txt > pca_meta.txt

#Generate BEAGLE file from VCF
angsd -vcf-gl autosomes.af.vcf.gz \
-doGlf 2 \
-doMajorMinor 1 \
-doMaf 1 \
-minMaf 0.05 \
-out buow

#output will be 'buow.beagle.gz'

#run pcangsd
pcangsd.py -beagle buow.beagle.gz -o buow_all -threads 8

